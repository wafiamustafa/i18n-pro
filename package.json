{
  "name": "i18n-ai-cli",
  "version": "1.0.0",
  "description": "AI-powered CLI tool for managing translation files in internationalized applications",
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "localization",
    "translation",
    "cli",
    "typescript",
    "ai",
    "openai",
    "gpt"
  ],
  "author": "Wafia Mustafa R.",
  "license": "ISC",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "i18n-ai-cli": "./dist/cli.js"
  },
  "dependencies": {
    "@vitalets/google-translate-api": "^9.2.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fs-extra": "^11.2.0",
    "glob": "^13.0.1",
    "inquirer": "^13.3.0",
    "iso-639-1": "^3.1.5",
    "leven": "^4.1.0",
    "openai": "^6.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
